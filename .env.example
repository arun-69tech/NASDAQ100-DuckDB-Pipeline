# =============================================================================
# Alpha Vantage Configuration
# =============================================================================
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_TIMEOUT_SECONDS=30
ALPHA_VANTAGE_OUTPUT_SIZE=compact

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_REGION=us-east-1
S3_BUCKET=marketvault-data

# =============================================================================
# Database Configuration
# =============================================================================
DUCKDB_DATABASE_PATH=data/marketvault.duckdb

# =============================================================================
# Configuration Files
# =============================================================================
TICKERS_FILE_PATH=config/tickers.csv

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/pipeline.log

# =============================================================================
# Pipeline Configuration
# =============================================================================
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=5

# =============================================================================
# Data Configuration
# =============================================================================
DATE_FORMAT=%Y-%m-%d
TIMESTAMP_FORMAT=%Y-%m-%d %H:%M:%S
